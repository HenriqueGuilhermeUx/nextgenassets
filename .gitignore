# Ambiente
.env
.env.local
.env.production
.env.development
.env.test

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Runtime
pids
*.pid
*.seed
*.pid.lock

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

