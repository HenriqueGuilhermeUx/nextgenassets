*.p12
*.pem
*.key
*.crt
cert-base64.txt
secrets/

# Banco de dados local
*.db
*.sqlite
*.sqlite3

# Cobertura de testes
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.eslintcache

# Terraform / IaC state
.terraform/
*.tfstate
*.tfstate.backup

