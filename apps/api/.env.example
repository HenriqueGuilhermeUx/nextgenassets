# ============================================
# NextGen Assets — API Environment (TEMPLATE)
# ============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no Git
# ============================================

# ===== Banco de dados (Supabase / Railway) =====
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.SEU_HOST.supabase.co:5432/postgres?sslmode=require"

# ===== Redis (Upstash / Railway) =====
REDIS_URL="redis://default:SUA_SENHA@SEU_HOST.upstash.io:6379"

# ===== Aplicação =====
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
WIDGET_URL=http://localhost:3005

# ===== CORS (separado por vírgula) =====
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ===== JWT (gere valores fortes em produção) =====
JWT_SECRET=trocar-em-producao-min-32-chars
JWT_REFRESH_SECRET=trocar-em-producao-outro-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== OpenAI =====
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o-mini
AI_CONFIDENCE_THRESHOLD=0.7

# ===== Anthropic (fallback) =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-haiku-4-5

# ===== Efí Bank (Open Finance + ITP) =====
# Sandbox: https://api-hml.efi.com.br/v1
# Produção: https://api.efi.com.br/v1
EFI_API_URL=https://api-hml.efi.com.br/v1
EFI_CLIENT_ID=Client_Id_xxxxx
EFI_CLIENT_SECRET=Client_Secret_xxxxx
EFI_PIX_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EFI_SANDBOX=true
# Certificado em base64 (gerar com: base64 -i cert.p12 | tr -d '\n')
EFI_CERTIFICATE_BASE64=

# ===== Woovi (Pix + Subcontas) =====
WOOVI_API_URL=https://api.woovi.com/v1
WOOVI_APP_ID=app_xxxxx
WOOVI_API_KEY=xxxxx
WOOVI_SANDBOX=true

# ===== WhatsApp =====
# Providers: zapi | twilio | business_api | evolution
WHATSAPP_PROVIDER=zapi
WHATSAPP_API_URL=https://api.z-api.io
WHATSAPP_INSTANCE_ID=xxxxx
WHATSAPP_TOKEN=xxxxx

# ===== Vault (desenvolvimento) =====
VAULT_URL=http://localhost:8200
VAULT_TOKEN=orkest-dev-token

# ===== BullMQ =====
BULL_PREFIX=nga

# ===== Sentry (opcional) =====
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ===== Observabilidade =====
LOG_LEVEL=debug
